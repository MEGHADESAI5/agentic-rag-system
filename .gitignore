# ==================================
# ROOT .gitignore - PROTECTS EVERYTHING
# ==================================

# ----- PYTHON (Flask / RAG API) -----
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
pip-log.txt
pip-delete-this-directory.txt

# ----- NODE / EXPRESS (Backend) -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ----- REACT (Frontend) -----
dist/
dist-ssr/
*.local

# ----- ENVIRONMENT VARIABLES (API KEYS - CRITICAL!) -----
.env
.env.local
.env.*.local
*.env

# ----- DATABASES & UPLOADS -----
chroma_db/
uploads/
*.db
*.sqlite3
*.sqlite

# ----- IDE & OS -----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ----- LOGS -----
logs/
*.log